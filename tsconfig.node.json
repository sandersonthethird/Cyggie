{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "lib": ["ESNext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./out/main",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@cyggie/shared": ["./packages/shared/src"],
      "@cyggie/shared/*": ["./packages/shared/src/*"],
      "@cyggie/services": ["./packages/services/src"],
      "@cyggie/services/*": ["./packages/services/src/*"],
      "@cyggie/db": ["./packages/db/src"],
      "@cyggie/db/*": ["./packages/db/src/*"]
    }
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "electron.vite.config.ts"
  ]
}
