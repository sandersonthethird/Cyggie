{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "lib": ["ESNext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./out/main",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@main/*": ["./src/main/*"],
      "@cyggie/shared": ["./packages/shared/src"],
      "@cyggie/shared/*": ["./packages/shared/src/*"],
      "@cyggie/services": ["./packages/services/src"],
      "@cyggie/services/*": ["./packages/services/src/*"],
      "@cyggie/db": ["./packages/db/src"],
      "@cyggie/db/*": ["./packages/db/src/*"]
    }
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "electron.vite.config.ts",
    // Workspace packages are imported via the @cyggie/* path aliases above.
    // List their sources so composite mode doesn't flag every transitively
    // imported file (e.g. connection.ts → migrations/*) with TS6307.
    "packages/db/src/**/*.ts",
    "packages/services/src/**/*.ts",
    "packages/shared/src/**/*.ts"
  ]
}
