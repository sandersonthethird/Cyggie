# pnpm settings — see https://docs.expo.dev/guides/monorepos/
#
# node-linker=hoisted: install all dependencies in a flat node_modules (like
# npm/yarn classic) rather than pnpm's symlink layout. Required because:
#   • React Native's CocoaPods autolinking scripts walk node_modules
#     filesystem-naively and don't follow pnpm's per-package symlinks.
#   • Metro's resolver is also happier with a flat layout.
#   • Electron's `electron-builder install-app-deps` postinstall rebuilds
#     native modules based on filesystem location.
#
# pnpm's strict version dedup still applies — if root, mobile, and web all
# declare react ^19.0.0, only one copy is installed (vs npm-workspaces which
# created three). That's the actual fix for the duplicate-React problem.
node-linker=hoisted

# Allow workspace packages to satisfy peer deps from sibling workspaces.
auto-install-peers=true

# Allow lifecycle scripts (electron-builder install-app-deps, native-module
# postinstall, expo-router's prebuild hooks, etc.).
enable-pre-post-scripts=true

# @electron/rebuild depends on @electron/node-gyp via a git URL. pnpm 11's
# default policy blocks exotic (git/file/tarball) deps inside the
# dependency tree. Allow them since Electron's tooling relies on this.
block-exotic-subdeps=false
