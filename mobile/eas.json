{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "image": "latest"
      },
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_GATEWAY_URL": "https://cyggie-gateway.fly.dev",
        "EXPO_PUBLIC_FEATURE_SUMMARY_TAB": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_GATEWAY_URL": "https://cyggie-gateway.fly.dev",
        "EXPO_PUBLIC_FEATURE_SUMMARY_TAB": "1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "REPLACE_WITH_APPLE_ID@example.com",
        "ascAppId": "REPLACE_WITH_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "REPLACE_WITH_APPLE_TEAM_ID"
      }
    }
  }
}
