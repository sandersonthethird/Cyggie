{
  "name": "echovault",
  "version": "0.1.0",
  "description": "Meeting Intelligence System - Real-time transcription and summarization",
  "main": "./out/main/index.js",
  "author": "Cyggie",
  "license": "MIT",
  "scripts": {
    "predev": "npx @electron/rebuild -f -w better-sqlite3 --buildFromSource && node scripts/build-native-helper.mjs",
    "dev": "node scripts/dev-electron.mjs",
    "dev:mobile-stack": "concurrently --names gateway,mobile --prefix-colors blue,green --kill-others-on-fail 'pnpm --filter @cyggie/api-gateway dev' 'pnpm --filter @cyggie/mobile dev'",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "package": "node scripts/build-native-helper.mjs --universal && electron-vite build && electron-builder --mac",
    "package:win": "electron-vite build && electron-builder --win",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "npm rebuild better-sqlite3 && vitest run && npx @electron/rebuild -f -w better-sqlite3 --buildFromSource",
    "test:watch": "npm rebuild better-sqlite3 && vitest",
    "import:granola": "node scripts/import-granola.js",
    "import:memos": "node scripts/import-memos-from-google-docs.js",
    "eval:transcription": "tsx --tsconfig tsconfig.node.json scripts/transcription-eval/run-eval.ts",
    "eval:company-extraction": "tsx --tsconfig tsconfig.node.json scripts/company-extraction-eval/run-eval.ts",
    "eval:slack-bot": "tsx --tsconfig tsconfig.node.json scripts/slack-bot-eval/run-eval.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@deepgram/sdk": "^3.9.0",
    "@fontsource/inter": "^5.2.8",
    "@tanstack/react-virtual": "^3.13.21",
    "@tiptap/extension-image": "^3.20.4",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.5",
    "@tiptap/extension-table": "^3.20.4",
    "@tiptap/markdown": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@types/turndown": "^5.0.6",
    "better-sqlite3": "^12.6.0",
    "csv-parse": "^6.1.0",
    "electron-audio-loopback": "^1.0.6",
    "exa-js": "^2.11.0",
    "exceljs": "^4.4.0",
    "googleapis": "^144.0.0",
    "lucide-react": "^1.6.0",
    "mammoth": "^1.12.0",
    "ollama": "^0.5.14",
    "openai": "^6.32.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.7.284",
    "react-native-markdown-display": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "turndown": "^7.2.2",
    "uuid": "^11.1.1",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^3.7.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "electron": "^40.8.5",
    "electron-builder": "^25.1.0",
    "electron-vite": "^5.0.0",
    "embedded-postgres": "17.10.0-beta.17",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "globals": "^14.0.0",
    "typescript-eslint": "^8.59.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^7.1.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "zustand": "^5.0.0"
  }
}
