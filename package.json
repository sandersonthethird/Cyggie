    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-vite build && electron-builder --mac",
    "package:win": "electron-vite build && electron-builder --win",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "npm rebuild better-sqlite3 && vitest run && npx @electron/rebuild -f -w better-sqlite3 --buildFromSource",
    "test:watch": "npm rebuild better-sqlite3 && vitest",
    "import:granola": "node scripts/import-granola.js",
    "import:memos": "node scripts/import-memos-from-google-docs.js"
  },
